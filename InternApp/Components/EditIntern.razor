@page "/editintern/{id:int}"

@using InternApp.Models
@inject InternApp.BLL.InternService internService
@inject NavigationManager Navigation

<h3>Edit Intern</h3>

<EditForm Model="@intern" OnValidSubmit="UpdateIntern">

    <div class="mb-3">
        <label>Name</label>
        <InputText class="form-control" @bind-Value="intern.Name" />
    </div>

    <div class="mb-3">
        <label>Email</label>
        <InputText class="form-control" @bind-Value="intern.Email" />
    </div>

    <div class="mb-3">
        <label>Department</label>
        <InputText class="form-control" @bind-Value="intern.Department" />
    </div>

    <div class="mb-3">
        <label>Duration (Months)</label>
        <InputNumber class="form-control" @bind-Value="intern.DurationInMonths" />
    </div>

    <button class="btn btn-primary">
        Update
    </button>

</EditForm>

@code {

    [Parameter]
    public int id { get; set; }

    InternApp.Models.Intern intern = new();

    protected override void OnInitialized()
    {
        intern = internService.GetInternById(id);
    }

    void UpdateIntern()
    {
        internService.UpdateIntern(intern);

        Navigation.NavigateTo("/interns");
    }

}
